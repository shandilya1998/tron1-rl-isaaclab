  <!-- ============================================================ -->
  <!--  JOINTS                                                       -->
  <!-- ============================================================ -->

  <!-- IMU fixed joint -->
  <joint name="limx_imu_joint" type="fixed">
    <parent link="base_Link"/>
    <child link="limx_imu"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Left leg -->
  <joint name="abad_L_Joint" type="revolute">
    <parent link="base_Link"/>
    <child link="abad_L_Link"/>
    <origin xyz="0.05556 0.105 -0.2602" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.3840" upper="1.3963" effort="40" velocity="23"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="hip_L_Joint" type="revolute">
    <parent link="abad_L_Link"/>
    <child link="hip_L_Link"/>
    <origin xyz="-0.077 0.0205 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0123" upper="1.3963" effort="60" velocity="20"/>
    <dynamics damping="0" friction="0"/>
